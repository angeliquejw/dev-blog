---
layout: layouts/default.njk
templateClass: tmpl-post
---

{%- if date | outOfDate %}
{% include "out-of-date.njk" %}
{%- endif %}

<div itemscope="itemscope" itemtype="http://schema.org/blogPost">
  <article>
    <header>
      <h1 itemprop="headline">{{ title }}</h1>
      <time datetime="{{ date | htmlDateString }}" itemprop="datePublished">{{ date | readableDate }}</time>
    </header>

    <div itemprop="text">
      {{ content | safe }}
    </div>

    {% if comments != false %}
      {% include "post-close.njk" %}
    {% endif %}

    {% if footnotes %}
      <ol class="footnotes">
        {% for note in footnotes %}
          {% set noteId = "fn" + loop.index %}
          <li id="{{ noteId }}">{{ note | safe }} <a href="#return-{{ noteId }}">&#x2934;</a></li>
        {% endfor %}
      </ol>
    {% endif %}
  </article>

      <p>Reading time: <em>{{ content | readingTime({speed:200}) }}</em></p>
      <p>Tagged as:</p>
      <ul class="u-list-reset" itemprop="keywords">
      {% for tag in tags %}
        {%- if collections.tagList.indexOf(tag) != -1 -%}
        {% set tagUrl %}/tags/{{ tag | slug }}/{% endset %}
        <li><a href="{{ tagUrl }}">{{ tag }}</a></li>
        {%- endif -%}
      {% endfor %}
      </ul>

    <nav aria-label="Pagination links">
      <ol class="u-list-reset">
      {% if prevPost.url %}
        <li>
          <a class="u-block" href="{{ prevPost.url }}">Older Post</a>
        </li>
      {% endif %}
      {% if nextPost.url %}
        <li>
          <a class="u-block" href="{{ nextPost.url }}">Newer Post</a>
        </li>
      {% endif %}
      </ol>
    </nav>

</div>

{% include "post-footer.njk" %}
