{%- if sky -%}
{%- for post in sky -%}
{%- if loop.last -%}
    <figure>
        <img src="{{post.img_url}}" alt="The sky on {{ post.timestamp | readableDateFromUNIX }}">
        <figcaption>My view on {{ post.timestamp | readableDateFromUNIX }}. See snaps from other dates in my <a href="/bits/the-sky/">gallery of sky photos</a>.</figcaption>
    </figure>
{%- endif -%}
{%- endfor -%}
{%- endif -%}
