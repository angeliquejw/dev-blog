{
	"name": "angeliqueweger.com",
	"version": "2.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"clean": "rm -rf _site && rm -rf .cache && rm -rf _dev",
		"get-books": "node src/assets/scripts/bookList.js",
		"start": "npm-run-all --parallel dev:*",
		"dev:eleventy": "ELEVENTY_ENV=development eleventy --quiet --serve --output=./_dev",
		"dev:v2": "cp ./src/v2/assets/ ./_dev/v2/ -r",
		"build": "run-s clean prod:*",
		"prod:eleventy": "ELEVENTY_ENV=production eleventy",
		"prod:v2": "cp ./src/v2/assets/ ./_site/v2/ -r",
		"prod:proof": "cp ./src/keybase.txt ./_site/",
		"lint": "npx stylelint 'src/assets/styles/*.css'",
		"debug": "run-s clean && DEBUG=* eleventy"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/angeliquejw/dev-blog.git"
	},
	"author": {
		"name": "Angélique Weger",
		"email": "hello@angeliqueweger.com",
		"url": "https://angeliqueweger.com/"
	},
	"resolutions": {
		"@babel/preset-env": "7.13.8"
	},
	"devDependencies": {
		"@11ty/eleventy": "^3.1.2",
		"@11ty/eleventy-plugin-rss": "^2.0.4",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
		"eleventy-plugin-reading-time": "0.0.1",
		"eleventy-plugin-vento": "^5.4.3",
		"luxon": "^3.7.2",
		"markdown-it": "^14.1.0",
		"markdown-it-abbr": "^2.0.0",
		"markdown-it-anchor": "^9.2.0",
		"markdown-it-attrs": "^4.3.1",
		"markdown-it-code-embed": "0.0.8",
		"markdown-it-prism": "^3.0.1",
		"minimage": "^2.0.5",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.1",
		"puppeteer": "^24.37.2",
		"puppeteer-extra": "^3.3.6",
		"puppeteer-extra-plugin-stealth": "^2.11.2",
		"stylelint": "^17.8.0",
		"stylelint-8-point-grid": "^5.0.1",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-order": "^7.0.1"
	},
	"dependencies": {
		"dotenv": "^17.3.1",
		"tumblr.js": "^5.0.1"
	}
}
